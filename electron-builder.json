{
    "appId": "com.teabox.winboat",
    "productName": "WinBoat",
    "directories": {
        "output": "dist"
    },
    "publish": null,
    "nsis": {
        "oneClick": false,
        "perMachine": false,
        "allowToChangeInstallationDirectory": true,
        "shortcutName": "WinBoat"
    },
    "win": {
        "target": "nsis"
    },
    "linux": {
        "icon": "icons/winboat_logo.svg",
        "target": [
            {
                "target": "appimage",
                "arch": ["x64", "arm64"]
            },
            {
                "target": "deb",
                "arch": ["x64", "arm64"]
            },
            {
                "target": "rpm",
                "arch": ["x64", "arm64"]
            },
            {
                "target": "tar.bz2",
                "arch": ["x64", "arm64"]
            }
        ],
        "category": "Utility",
        "artifactName": "${name}-${version}-${arch}.${ext}"
    },
    "files": [
        {
            "from": "build/main",
            "to": "main",
            "filter": ["**/*"]
        },
        {
            "from": "build/renderer",
            "to": "renderer",
            "filter": ["**/*"]
        },
        {
            "from": "src/main/static",
            "to": "static",
            "filter": ["**/*"]
        },
        "!build",
        "!dist",
        "!scripts"
    ],
    "extraResources": [
        {
            "from": "./guest_server/winboat_guest_server_${arch}.zip",
            "to": "guest_server/winboat_guest_server.zip"
        },
        {
            "from": "./data",
            "to": "data",
            "filter": ["**/*"]
        }
    ]
}
